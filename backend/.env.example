DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/securo
SECRET_KEY=change-me-in-production
DEBUG=true
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_OAUTH_REDIRECT_URI=http://localhost:5173/oauth/callback
FRONTEND_URL=http://localhost:5173
REDIS_URL=redis://localhost:6379/0
# Brazilian Treasury bond prices. On by default; set to false to disable
# (e.g. to avoid the dependency on the Brazilian government CSV endpoint).
TESOURO_DIRETO_ENABLED=true

# Optional OIDC login (Authentik, Pocket ID, or standard OIDC providers)
OIDC_ENABLED=false
OIDC_PROVIDER_NAME=OIDC
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Defaults to ${FRONTEND_URL}/api/auth/oidc/callback
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid email profile
OIDC_AUTO_REGISTER=true
OIDC_REQUIRE_VERIFIED_EMAIL=true
OIDC_SYNC_ROLES=false
OIDC_ROLES_CLAIM=groups
OIDC_ADMIN_ROLES=
OIDC_WORKSPACE_ROLE_MAP=
